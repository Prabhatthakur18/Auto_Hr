generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── USERS (Login credentials) ───────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique @db.VarChar(50)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         Role     @default(EMPLOYEE)
  employeeId   Int?     @unique @map("employee_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  employee      Employee?      @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  announcements Announcement[]
  approvedLeaves Leave[]       @relation("ApprovedBy")

  @@map("users")
}

enum Role {
  EMPLOYEE
  MANAGER
  HR
}

// ─── EMPLOYEES (Profile data) ────────────────────────────────

model Employee {
  id           Int      @id @default(autoincrement())
  biometricId  Int?     @unique @map("biometric_id")
  name         String   @db.VarChar(100)
  position     String?  @db.VarChar(100)
  department   String?  @db.VarChar(100)
  email        String?  @unique @db.VarChar(100)
  phone        String?  @db.VarChar(20)
  joinDate     DateTime? @map("join_date") @db.Date
  managerId    Int?     @map("manager_id")
  avatar       String?  @db.VarChar(500)
  bio          String?  @db.Text
  skills       Json?
  experience   String?  @db.Text
  education    String?  @db.VarChar(255)
  employeeType String?  @map("employee_type") @db.VarChar(50)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Self-relation: manager
  manager      Employee?  @relation("ManagerReports", fields: [managerId], references: [id], onDelete: SetNull)
  directReports Employee[] @relation("ManagerReports")

  // Other relations
  user              User?
  attendance        Attendance[]
  leaves            Leave[]
  salaryBreakdowns  SalaryBreakdown[]
  salarySlips       SalarySlip[]

  @@map("employees")
}

// ─── ATTENDANCE ──────────────────────────────────────────────

model Attendance {
  id                Int              @id @default(autoincrement())
  employeeId        Int              @map("employee_id")
  date              DateTime         @db.Date
  day               String?          @db.VarChar(10)
  checkIn           String?          @map("check_in") @db.VarChar(10)
  checkOut          String?          @map("check_out") @db.VarChar(10)
  totalWorkingHours String?          @map("total_working_hours") @db.VarChar(10)
  isLate            Boolean          @default(false) @map("is_late")
  lateBy            String?          @map("late_by") @db.VarChar(30)
  overtime          Boolean          @default(false)
  otTime            String?          @map("ot_time") @db.VarChar(10)
  status            AttendanceStatus @default(PRESENT)
  createdAt         DateTime         @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@map("attendance")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  ON_LEAVE
  HOLIDAY
}

// ─── LEAVES ──────────────────────────────────────────────────

model Leave {
  id          Int         @id @default(autoincrement())
  employeeId  Int         @map("employee_id")
  type        String      @db.VarChar(50)
  startDate   DateTime    @map("start_date") @db.Date
  endDate     DateTime    @map("end_date") @db.Date
  days        Int
  status      LeaveStatus @default(PENDING)
  reason      String?     @db.Text
  approvedById Int?       @map("approved_by_id")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approvedBy User?    @relation("ApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@map("leaves")
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── SALARY BREAKDOWN ────────────────────────────────────────

model SalaryBreakdown {
  id               Int      @id @default(autoincrement())
  employeeId       Int      @map("employee_id")
  basicSalary      Decimal  @default(0) @map("basic_salary") @db.Decimal(10, 2)
  hra              Decimal  @default(0) @db.Decimal(10, 2)
  da               Decimal  @default(0) @db.Decimal(10, 2)
  ta               Decimal  @default(0) @db.Decimal(10, 2)
  medicalAllowance Decimal  @default(0) @map("medical_allowance") @db.Decimal(10, 2)
  specialAllowance Decimal  @default(0) @map("special_allowance") @db.Decimal(10, 2)
  pf               Decimal  @default(0) @db.Decimal(10, 2)
  esi              Decimal  @default(0) @db.Decimal(10, 2)
  tax              Decimal  @default(0) @db.Decimal(10, 2)
  otherDeductions  Decimal  @default(0) @map("other_deductions") @db.Decimal(10, 2)
  effectiveFrom    DateTime @map("effective_from") @db.Date
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("salary_breakdowns")
}

// ─── SALARY SLIPS ────────────────────────────────────────────

model SalarySlip {
  id              Int      @id @default(autoincrement())
  employeeId      Int      @map("employee_id")
  month           String   @db.VarChar(7) // "2026-03"
  grossSalary     Decimal  @map("gross_salary") @db.Decimal(10, 2)
  totalDeductions Decimal  @map("total_deductions") @db.Decimal(10, 2)
  netSalary       Decimal  @map("net_salary") @db.Decimal(10, 2)
  workingDays     Int      @map("working_days")
  daysPresent     Int      @map("days_present")
  breakdownJson   Json?    @map("breakdown_json")
  generatedAt     DateTime @default(now()) @map("generated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month])
  @@map("salary_slips")
}

// ─── ANNOUNCEMENTS ───────────────────────────────────────────

model Announcement {
  id            Int                  @id @default(autoincrement())
  title         String               @db.VarChar(255)
  content       String?              @db.Text
  priority      AnnouncementPriority @default(LOW)
  attachmentUrl String?              @map("attachment_url") @db.VarChar(500)
  createdById   Int                  @map("created_by_id")
  isActive      Boolean              @default(true) @map("is_active")
  createdAt     DateTime             @default(now()) @map("created_at")
  expiresAt     DateTime?            @map("expires_at")

  createdBy User @relation(fields: [createdById], references: [id])

  @@map("announcements")
}

enum AnnouncementPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
